# 1. Môi trường ảo (Virtual Environment) - Cực kỳ nặng, không bao giờ đẩy lên Git
algvenv/
venv/
ENV/

# 2. Bảo mật - Chứa Gemini API Key của bạn (Tuyệt đối không để lộ!)
.env

# 3. Cơ sở dữ liệu và Chỉ mục (Database & Index) - Chỉ sinh ra khi chạy local
legal_vector_db/
data/vector_db/
data/bm25_index.pkl

# 4. Các file Word tạm thời do MS Word sinh ra khi đang mở file (Lock files)
docs/~$*.docx
docs/~$*.doc
~$*.docx

# 5. Các file cache của Python (Sinh ra khi bạn chạy code)
**/__pycache__/
*.py[cod]
*$py.class

# 6. Metadata cấu hình cục bộ của công cụ đóng gói (Editable mode)
*.egg-info/
.eggs/